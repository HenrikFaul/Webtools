    {
      "name": "⚡ NewsScout Agent",
      "description": "Az n8n/webhook agent manuális indítása és futások nyomonkövetése",
      "item": [
        {
          "name": "Trigger – Agent futtatás indítása",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"force\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/news-scout/trigger",
              "host": ["{{base_url}}"],
              "path": ["api", "news-scout", "trigger"]
            },
            "description": "Az n8n webhook agent indítása.\n\n- `force: false` — megtagadja ha már fut egy aktív run (max_concurrent alapján)\n- `force: true` — mindenképp elindít egy új futást\n\nA válasz `run_id`-ját a Tests tab automatikusan beállítja az environment `run_id` változóba."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 vagy 409', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 409]);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.run_id) {",
                  "    pm.environment.set('run_id', json.run_id);",
                  "    console.log('run_id beállítva:', json.run_id);",
                  "    console.log('Webhook hívva:', json.webhook_called);",
                  "    if (json.webhook_error) console.warn('Webhook hiba:', json.webhook_error);",
                  "} else if (json.error === 'already_active') {",
                  "    console.warn('Már fut:', json.active_runs?.length, 'aktív futás');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Trigger – Force indítás (aktív run ellenére)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"force\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/news-scout/trigger",
              "host": ["{{base_url}}"],
              "path": ["api", "news-scout", "trigger"]
            }
          },
          "response": []
        },
        {
          "name": "Runs – Futások listája",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/news-scout/runs?page=1&pageSize=20",
              "host": ["{{base_url}}"],
              "path": ["api", "news-scout", "runs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "json.runs?.slice(0, 5).forEach(r => {",
                  "    console.log(r.status.padEnd(12), r.run_id, r.started_at);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Runs – Aktív futások",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/news-scout/runs/active",
              "host": ["{{base_url}}"],
              "path": ["api", "news-scout", "runs", "active"]
            },
            "description": "Jelenleg futó (queued/running) futások listája."
          },
          "response": []
        },
        {
          "name": "Run – Heartbeat ellenőrzés",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"progress_processed\": 10,\n  \"progress_total\": 100\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/news-scout/runs/{{run_id}}/heartbeat",
              "host": ["{{base_url}}"],
              "path": ["api", "news-scout", "runs", "{{run_id}}", "heartbeat"]
            },
            "description": "Agent heartbeat küldése — watchdog erre figyel. Állítsd be a `run_id` environment változót."
          },
          "response": []
        },
        {
          "name": "Run – Leállítás (cancel)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/news-scout/runs/{{run_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "news-scout", "runs", "{{run_id}}", "cancel"]
            }
          },
          "response": []
        }
      ]
    },
